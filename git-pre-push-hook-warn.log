        <!doctype html>
        <html lang="zh-CN">
        <head>
          <meta charset="utf-8">
          <meta name="viewport" content="width=device-width, initial-scale=1.0">
          <title>OceanBase X · AI Landscape</title>
          <link rel="preconnect" href="https://fonts.googleapis.com">
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
          <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..900;1,14..32,300..900&family=Noto+Sans+SC:wght@300;400;500;700;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
          <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
          <style>
            :root {
              --blue: #1a1aff;
              --teal: #00d4aa;
              --ghost: #b0afa7;
              --green: #2aa84a;
              --dgreen: #1e8e3e;
              --blue2: #2f7dd1;
              --lblue: #4aa3df;
              --gray: #7a7d82;
              --dgray: #6b6f74;
            }
            *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
            html, body { height: 100%; }
            body {
              background: #0a0a0f;
              color: #e8e8ed;
              font-family: 'Inter', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
              -webkit-font-smoothing: antialiased;
              overflow-x: hidden;
            }
        
            /* ── Top bar ── */
            .top-bar {
              position: fixed; top: 0; left: 0; right: 0; z-index: 100;
              background: rgba(10,10,15,0.85);
              backdrop-filter: blur(16px);
              border-bottom: 1px solid rgba(255,255,255,0.06);
              display: flex; align-items: center; justify-content: space-between;
              padding: 0 40px; height: 50px;
            }
            .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; color: #e8e8ed; }
            .brand img { height: 24px; display: block; }
            .brand-name { font-family: 'Inter', sans-serif; font-weight: 700; font-size: 15px; color: #fff; letter-spacing: -0.02em; }
            .brand-divider { width: 1px; height: 12px; background: rgba(255,255,255,0.15); }
            .brand-tag {
              font-family: 'JetBrains Mono', monospace;
              font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ghost);
            }
            .lang-switch {
              font-family: 'JetBrains Mono', monospace;
              font-size: 10px; letter-spacing: 0.06em;
              display: flex; align-items: center; gap: 4px;
            }
            .lang-switch a { color: rgba(255,255,255,0.35); text-decoration: none; padding: 4px 8px; transition: color 0.15s; }
            .lang-switch a.active { color: #e8e8ed; }
            .lang-switch a:hover:not(.active) { color: rgba(255,255,255,0.6); }
            .lang-switch .sep { color: rgba(255,255,255,0.15); }
        
            /* ── Main layout ── */
            .landscape-canvas {
              width: 100%; min-height: 100vh;
              padding: 70px 32px 40px;
              position: relative;
            }
            .landscape-title {
              text-align: center; margin-bottom: 32px; position: relative; z-index: 2;
            }
            .landscape-title h1 {
              font-size: clamp(24px, 3.5vw, 42px); font-weight: 800;
              letter-spacing: -0.03em; color: #fff; margin-bottom: 6px;
            }
            .landscape-title h1 .ab { color: var(--blue); }
            .landscape-title h1 .at { color: var(--teal); }
            .landscape-title p {
              font-size: 12px; color: rgba(255,255,255,0.4);
              font-family: 'JetBrains Mono', monospace; letter-spacing: 0.06em;
            }
        
            /* ── Split layout: left 70% / right 30% ── */
            .split-layout {
              display: grid;
              grid-template-columns: 7fr 3fr;
              gap: 24px;
              max-width: 1440px;
              margin: 0 auto;
              position: relative; z-index: 2;
            }
        
            /* ── LEFT: Landscape canvas ── */
            .land-left { min-width: 0; }
        
            /* ── Flow legend ── */
            .flow-legend {
              display: flex; gap: 20px; justify-content: center; margin-bottom: 14px;
            }
            .fl-item {
              display: flex; align-items: center; gap: 6px;
              font-size: 10px; color: rgba(255,255,255,0.35);
              font-family: 'JetBrains Mono', monospace;
            }
            .fl-dot {
              width: 7px; height: 7px; border-radius: 50%;
              animation: flPulse 2s ease-in-out infinite;
            }
            .fl-dot.blue { background: var(--blue); box-shadow: 0 0 6px rgba(26,26,255,0.5); }
            .fl-dot.teal { background: var(--teal); box-shadow: 0 0 6px rgba(0,212,170,0.5); }
            @keyframes flPulse { 0%,100%{opacity:.4} 50%{opacity:1} }
        
            /* Architecture rows */
            .arch-stack {
              display: flex; flex-direction: column; gap: 0;
            }
            .arch-row {
              display: grid; grid-template-columns: 140px 1fr;
              gap: 6px; align-items: stretch;
              border-radius: 10px;
              overflow: hidden;
              transition: box-shadow 0.3s, opacity 0.3s;
            }
            .arch-row.is-active {
              box-shadow: 0 0 0 2px var(--blue), 0 0 24px rgba(26,26,255,0.12);
            }
            .arch-side {
              display: flex; align-items: center; justify-content: center;
              padding: 12px 8px; font-weight: 700; font-size: 13px;
              letter-spacing: 0.04em; color: #fff; text-align: center;
              cursor: pointer; transition: filter 0.2s, transform 0.15s;
              user-select: none;
            }
            .arch-side:hover { filter: brightness(1.15); }
            .arch-side .side-icon { font-size: 16px; margin-right: 6px; }
            .arch-body {
              display: flex; gap: 8px; padding: 8px 10px;
              flex-wrap: wrap; align-items: stretch;
              border-radius: 0 10px 10px 0;
              transition: background 0.3s;
            }
        
            /* Row colour themes */
            .arch-row.t-green  .arch-side { background: var(--green); }
            .arch-row.t-green  .arch-body { background: rgba(42,168,74,0.06); border: 1px solid rgba(42,168,74,0.2); border-left: none; }
            .arch-row.t-gray   .arch-side { background: var(--gray); }
            .arch-row.t-gray   .arch-body { background: rgba(122,125,130,0.06); border: 1px solid rgba(122,125,130,0.2); border-left: none; }
            .arch-row.t-blue   .arch-side { background: var(--blue2); }
            .arch-row.t-blue   .arch-body { background: rgba(47,125,209,0.06); border: 1px solid rgba(47,125,209,0.2); border-left: none; }
            .arch-row.t-dgreen .arch-side { background: var(--dgreen); }
            .arch-row.t-dgreen .arch-body { background: rgba(30,142,62,0.06); border: 1px solid rgba(30,142,62,0.2); border-left: none; }
            .arch-row.t-lblue  .arch-side { background: var(--lblue); }
            .arch-row.t-lblue  .arch-body { background: rgba(74,163,223,0.05); border: 1px solid rgba(74,163,223,0.18); border-left: none; }
            .arch-row.t-compute .arch-side { background: var(--dgray); }
            .arch-row.t-compute .arch-body { background: rgba(107,111,116,0.06); border: 1px solid rgba(107,111,116,0.2); border-left: none; }
        
            /* Active row highlight */
            .arch-row.is-active.t-green  { box-shadow: 0 0 0 2px var(--green), 0 0 20px rgba(42,168,74,0.15); }
            .arch-row.is-active.t-gray   { box-shadow: 0 0 0 2px var(--gray), 0 0 20px rgba(122,125,130,0.15); }
            .arch-row.is-active.t-blue   { box-shadow: 0 0 0 2px var(--blue2), 0 0 20px rgba(47,125,209,0.15); }
            .arch-row.is-active.t-dgreen { box-shadow: 0 0 0 2px var(--dgreen), 0 0 20px rgba(30,142,62,0.15); }
            .arch-row.is-active.t-lblue  { box-shadow: 0 0 0 2px var(--lblue), 0 0 20px rgba(74,163,223,0.15); }
            .arch-row.is-active.t-compute{ box-shadow: 0 0 0 2px var(--dgray), 0 0 20px rgba(107,111,116,0.15); }
        
            /* Dim rows (engine layers) */
            .arch-row.is-dim { opacity: 0.45; }
            .arch-row.is-dim:hover { opacity: 0.75; }
            .arch-row.is-dim.is-active { opacity: 1; }
        
            /* Chips inside rows */
            .arch-chip {
              flex: 1 1 auto; min-width: 90px;
              display: flex; flex-direction: column; align-items: center; justify-content: center;
              padding: 10px 12px; border-radius: 7px;
              font-size: 12px; font-weight: 600; color: #fff; text-align: center;
              text-decoration: none;
              transition: transform 0.15s, box-shadow 0.2s, filter 0.2s;
              cursor: pointer; user-select: none;
            }
            .arch-chip:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.3); filter: brightness(1.12); }
            .arch-chip.is-focused { transform: translateY(-2px) scale(1.04); box-shadow: 0 0 0 2px #fff, 0 6px 20px rgba(0,0,0,0.35); filter: brightness(1.2); z-index: 5; }
            .arch-chip.c-green  { background: var(--green); }
            .arch-chip.c-gray   { background: var(--gray); }
            .arch-chip.c-blue   { background: var(--blue2); }
            .arch-chip.c-dgreen { background: var(--dgreen); }
            .arch-chip.c-lblue  { background: var(--lblue); }
            .arch-chip.c-dgray  { background: var(--dgray); }
            .arch-chip.c-dots   { background: transparent; color: rgba(255,255,255,0.4); font-size: 16px; cursor: default; }
            .arch-chip.c-dots:hover { transform: none; box-shadow: none; filter: none; }
            .arch-chip .chip-sub { font-size: 10px; opacity: 0.7; margin-top: 2px; font-weight: 400; }
        
            /* ── Flow connectors between layers ── */
            .flow-conn {
              display: flex;
              align-items: center;
              gap: 10px;
              margin-left: 148px;
              height: 28px;
            }
            .flow-rail {
              position: relative;
              width: 16px;
              height: 100%;
            }
            .fr-line {
              position: absolute;
              left: 3px; width: 1px; top: 0; bottom: 0;
              background: rgba(26,26,255,0.1);
            }
            .fr-line2 {
              position: absolute;
              right: 3px; width: 1px; top: 0; bottom: 0;
              background: rgba(0,212,170,0.1);
            }
            .fr-dot {
              position: absolute;
              width: 5px; height: 5px;
              border-radius: 50%;
            }
            .fr-dot.q {
              left: 1px;
              background: var(--blue);
              box-shadow: 0 0 8px rgba(26,26,255,0.6);
              animation: flowQ 2.2s linear infinite;
            }
            .fr-dot.r {
              right: 1px;
              background: var(--teal);
              box-shadow: 0 0 8px rgba(0,212,170,0.6);
              animation: flowR 2.2s linear infinite;
            }
            @keyframes flowQ {
              0%   { top: -5px; opacity: 0; }
              12%  { opacity: 1; }
              88%  { opacity: 1; }
              100% { top: 100%; opacity: 0; }
            }
            @keyframes flowR {
              0%   { top: 100%; opacity: 0; }
              12%  { opacity: 1; }
              88%  { opacity: 1; }
              100% { top: -5px; opacity: 0; }
            }
            .flow-label {
              font-size: 9px;
              color: rgba(255,255,255,0.22);
              font-family: 'JetBrains Mono', monospace;
              letter-spacing: 0.05em;
              white-space: nowrap;
            }
        
            /* Zone boundary (between L3 and L4) */
            .flow-conn.is-gate {
              margin-left: 0;
              justify-content: center;
              padding: 5px 0;
              gap: 14px;
            }
            .flow-conn.is-gate::before,
            .flow-conn.is-gate::after {
              content: '';
              flex: 1;
              max-width: 120px;
              height: 1px;
              background: linear-gradient(90deg, transparent, rgba(26,26,255,0.18), transparent);
            }
            .zone-tag {
              font-size: 10px;
              font-weight: 700;
              letter-spacing: 0.12em;
              text-transform: uppercase;
              font-family: 'JetBrains Mono', monospace;
              padding: 3px 14px;
              border-radius: 4px;
            }
            .zone-tag.app   { color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.05); }
            .zone-tag.engine { color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.02); }
        
            /* ── Focus detail panel (below landscape) ── */
            .focus-panel {
              margin-top: 16px;
              background: rgba(255,255,255,0.03);
              border: 1px solid rgba(255,255,255,0.08);
              border-radius: 12px;
              padding: 20px 24px;
              min-height: 80px;
              transition: border-color 0.3s;
            }
            .focus-panel.has-focus { border-color: rgba(26,26,255,0.3); }
            .focus-panel-header {
              display: flex; align-items: center; gap: 10px; margin-bottom: 10px;
            }
            .focus-panel-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
            .focus-panel-title { font-size: 16px; font-weight: 700; color: #fff; }
            .focus-panel-layer {
              font-family: 'JetBrains Mono', monospace;
              font-size: 10px; letter-spacing: 0.08em; color: rgba(255,255,255,0.4);
              margin-left: auto;
            }
            .focus-panel-desc { font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.7; }
            .focus-panel-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
            .focus-tag {
              padding: 4px 12px; border-radius: 999px;
              background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
              font-size: 11px; color: rgba(255,255,255,0.6);
              font-family: 'JetBrains Mono', monospace;
            }
            .focus-placeholder {
              color: rgba(255,255,255,0.25); font-size: 13px;
              font-family: 'JetBrains Mono', monospace;
            }
        
            /* ── RIGHT: OB AI Ecosystem nav panel ── */
            .land-right { min-width: 0; }
            .eco-panel {
              background: rgba(255,255,255,0.02);
              border: 1px solid rgba(255,255,255,0.06);
              border-radius: 14px;
              padding: 20px;
              position: sticky; top: 70px;
            }
            .eco-panel-head { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
            .eco-panel-icon {
              width: 28px; height: 28px; border-radius: 8px;
              background: linear-gradient(135deg, var(--blue), var(--teal));
              display: flex; align-items: center; justify-content: center;
              font-size: 14px; color: #fff;
            }
            .eco-panel-title { font-size: 15px; font-weight: 800; color: #fff; }
            .eco-panel-sub {
              font-size: 10px; color: rgba(255,255,255,0.35);
              font-family: 'JetBrains Mono', monospace;
              letter-spacing: 0.06em; margin-bottom: 16px;
            }
            .eco-section-label {
              font-family: 'JetBrains Mono', monospace;
              font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
              color: rgba(255,255,255,0.25); margin-bottom: 8px; margin-top: 16px;
            }
            .eco-section-label:first-of-type { margin-top: 0; }
            .eco-item {
              display: flex; align-items: center; gap: 10px;
              padding: 10px 12px; border-radius: 8px;
              background: rgba(255,255,255,0.02);
              border: 1px solid rgba(255,255,255,0.05);
              margin-bottom: 6px;
              text-decoration: none; color: inherit;
              transition: all 0.2s; cursor: pointer;
            }
            .eco-item:hover {
              border-color: var(--blue); background: rgba(26,26,255,0.06);
              transform: translateX(3px);
            }
            .eco-item.is-active {
              border-color: var(--blue); background: rgba(26,26,255,0.1);
              box-shadow: 0 0 12px rgba(26,26,255,0.1);
            }
            .eco-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
            .eco-dot.blue { background: var(--blue); }
            .eco-dot.teal { background: var(--teal); }
            .eco-dot.green { background: var(--green); }
            .eco-dot.gray { background: var(--gray); }
            .eco-info { flex: 1; min-width: 0; }
            .eco-name { font-size: 13px; font-weight: 600; color: #fff; }
            .eco-desc { font-size: 10px; color: rgba(255,255,255,0.4); margin-top: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
            .eco-arrow { color: rgba(255,255,255,0.2); font-size: 14px; transition: color 0.15s, transform 0.15s; }
            .eco-item:hover .eco-arrow { color: var(--blue); transform: translateX(2px); }
        
            /* ── Footer ── */
            .site-footer {
              padding: 32px 40px; margin-top: 40px;
              display: flex; align-items: center; justify-content: center; gap: 16px;
              font-family: 'JetBrains Mono', monospace;
              font-size: 10px; letter-spacing: 0.06em; color: rgba(255,255,255,0.2);
              flex-wrap: wrap;
            }
            .site-footer a { color: rgba(255,255,255,0.3); text-decoration: none; transition: color 0.15s; }
            .site-footer a:hover { color: rgba(255,255,255,0.7); }
            .site-footer .sep { color: rgba(255,255,255,0.1); }
        
            /* ── Background ── */
            .bg-grid {
              position: fixed; inset: 0;
              background-image:
                linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
              background-size: 48px 48px; pointer-events: none; z-index: 0;
            }
            .bg-glow {
              position: fixed; width: 600px; height: 600px; border-radius: 50%;
              filter: blur(120px); pointer-events: none; z-index: 0;
            }
            .bg-glow.blue { top: 30%; left: 30%; background: rgba(26,26,255,0.06); }
            .bg-glow.teal { top: 55%; left: 60%; background: rgba(0,212,170,0.04); }
        
            /* ── Responsive ── */
            @media (max-width: 1024px) {
              .split-layout { grid-template-columns: 1fr; gap: 20px; }
              .eco-panel { position: static; }
            }
            @media (max-width: 768px) {
              .top-bar { padding: 0 16px; }
              .landscape-canvas { padding: 62px 12px 20px; }
              .landscape-title { margin-bottom: 20px; }
              .arch-row { grid-template-columns: 1fr; }
              .arch-side { border-radius: 8px 8px 0 0; padding: 8px; font-size: 12px; }
              .arch-body { border-radius: 0 0 8px 8px; }
              .arch-chip { min-width: 70px; font-size: 11px; padding: 8px 8px; }
              .flow-conn { margin-left: 0; justify-content: center; }
              .flow-conn.is-gate { gap: 8px; }
              .zone-tag { font-size: 8px; padding: 2px 8px; }
              .eco-panel { padding: 14px; }
            }
          </style>
        </head>
        <body>
          <div class="bg-grid"></div>
          <div class="bg-glow blue"></div>
          <div class="bg-glow teal"></div>
        
          <header class="top-bar">
            <a class="brand" href="index_zh.html">
              <img src="assets/logo.png" alt="OceanBase">
              <span class="brand-name">OceanBase</span>
              <span class="brand-divider"></span>
              <span class="brand-tag">AI Landscape</span>
            </a>
            <nav class="lang-switch">
              <a class="active" href="index_zh.html">中文</a>
              <span class="sep">/</span>
              <a href="index_en.html">EN</a>
            </nav>
          </header>
        
          <main class="landscape-canvas">
            <div class="landscape-title">
              <h1>OceanBase <span class="ab">AI</span> <span class="at">Ecosystem</span></h1>
              <p>向量数据库 · 全栈 AI 基础设施</p>
            </div>
        
            <div class="split-layout">
              <!-- ═══ LEFT 70%: Landscape ═══ -->
              <div class="land-left">
        
                <!-- Flow legend -->
                <div class="flow-legend">
                  <span class="fl-item"><span class="fl-dot blue"></span>查询请求 Query</span>
                  <span class="fl-item"><span class="fl-dot teal"></span>检索结果 Result</span>
                </div>
        
                <div class="arch-stack" id="archStack">
        
                  <!-- ━━ Layer 1: 应用场景 ━━ -->
                  <div class="arch-row t-green" data-layer="1" data-layer-name="应用场景">
                    <div class="arch-side"><i class="ri-apps-2-line side-icon"></i>应用场景</div>
                    <div class="arch-body">
                      <div class="arch-chip c-green" data-focus="rag">检索增强生成 (RAG)<span class="chip-sub">Retrieval-Augmented Generation</span></div>
                      <div class="arch-chip c-green" data-focus="semantic">语义搜索<span class="chip-sub">Semantic Search</span></div>
                      <div class="arch-chip c-green" data-focus="multimodal">多模态搜索<span class="chip-sub">Multi-Modal Search</span></div>
                      <div class="arch-chip c-green" data-focus="agent">智能体应用<span class="chip-sub">Agent Applications</span></div>
                    </div>
                  </div>
        
                  <!-- Flow L1 → L2 -->
                  <div class="flow-conn">
                    <div class="flow-rail">
                      <div class="fr-line"></div><div class="fr-line2"></div>
                      <span class="fr-dot q" style="animation-delay:0s"></span>
                      <span class="fr-dot q" style="animation-delay:1.1s"></span>
                      <span class="fr-dot r" style="animation-delay:0.5s"></span>
                      <span class="fr-dot r" style="animation-delay:1.6s"></span>
                    </div>
                    <span class="flow-label">用户查询 ↓ · AI 响应 ↑</span>
                  </div>
        
                  <!-- ━━ Layer 2: AI 生态 ━━ -->
                  <div class="arch-row t-blue" data-layer="2" data-layer-name="AI 生态">
                    <div class="arch-side"><i class="ri-plug-line side-icon"></i>AI 生态</div>
                    <div class="arch-body">
                      <a class="arch-chip c-blue" href="ob-langchain/index.html" data-focus="langchain">LangChain</a>
                      <div class="arch-chip c-blue" data-focus="llamaindex">LlamaIndex</div>
                      <div class="arch-chip c-blue" data-focus="fastgpt">FastGPT</div>
                      <a class="arch-chip c-blue" href="ob-dify/index.html" data-focus="dify">Dify</a>
                      <div class="arch-chip c-blue" data-focus="dbgpt">DB-GPT</div>
                      <div class="arch-chip c-blue" data-focus="springai">Spring AI</div>
                      <a class="arch-chip c-blue" href="ob-ragflow/index.html" data-focus="ragflow">RAGFlow</a>
                      <div class="arch-chip c-blue" data-focus="autogen">AutoGen</div>
                      <div class="arch-chip c-blue" data-focus="crewai">CrewAI</div>
                      <div class="arch-chip c-dots">...</div>
                    </div>
                  </div>
        
                  <!-- Flow L2 → L3 -->
                  <div class="flow-conn">
                    <div class="flow-rail">
                      <div class="fr-line"></div><div class="fr-line2"></div>
                      <span class="fr-dot q" style="animation-delay:0.2s"></span>
                      <span class="fr-dot q" style="animation-delay:1.3s"></span>
                      <span class="fr-dot r" style="animation-delay:0.7s"></span>
                      <span class="fr-dot r" style="animation-delay:1.8s"></span>
                    </div>
                    <span class="flow-label">框架 API 调用 ↓ · 结构化结果 ↑</span>
                  </div>
        
                  <!-- ━━ Layer 3: 用户接口 ━━ -->
                  <div class="arch-row t-gray" data-layer="3" data-layer-name="用户接口">
                    <div class="arch-side"><i class="ri-code-s-slash-line side-icon"></i>用户接口</div>
                    <div class="arch-body">
                      <div class="arch-chip c-gray" style="flex:1;" data-focus="pysdk">Python SDK<span class="chip-sub">pyobvector · pyseekdb</span></div>
                      <div class="arch-chip c-gray" style="flex:1;" data-focus="javasdk">Java SDK<span class="chip-sub">Connector/J · Spring Data</span></div>
                      <div class="arch-chip c-gray" style="flex:1.2;" data-focus="mysqlclient">MySQL 多语言客户端<span class="chip-sub">Go · Rust · Node.js · PHP</span></div>
                    </div>
                  </div>
        
                  <!-- ━━ Zone boundary: 应用层 → 引擎层 ━━ -->
                  <div class="flow-conn is-gate">
                    <span class="zone-tag app">应用层</span>
                    <div class="flow-rail">
                      <div class="fr-line"></div><div class="fr-line2"></div>
                      <span class="fr-dot q" style="animation-delay:0.1s"></span>
                      <span class="fr-dot r" style="animation-delay:0.6s"></span>
                    </div>
                    <span class="zone-tag engine">引擎层</span>
                  </div>
        
                  <!-- ━━ Layer 4: 混合检索 (simplified) ━━ -->
                  <div class="arch-row t-blue" data-layer="4" data-layer-name="混合检索">
                    <div class="arch-side"><i class="ri-search-line side-icon"></i>混合检索</div>
                    <div class="arch-body">
                      <div class="arch-chip c-blue" style="flex:1.2;" data-focus="scalarvec">标量+向量过滤<span class="chip-sub">Pre / In / Post-filter</span></div>
                      <div class="arch-chip c-blue" style="flex:1;" data-focus="multivec">多向量检索<span class="chip-sub">Multi-Vector</span></div>
                      <div class="arch-chip c-blue" style="flex:1;" data-focus="ftvec">全文+向量<span class="chip-sub">BM25 + ANN</span></div>
                    </div>
                  </div>
        
                  <!-- Flow L4 → L5 -->
                  <div class="flow-conn">
                    <div class="flow-rail">
                      <div class="fr-line"></div><div class="fr-line2"></div>
                      <span class="fr-dot q" style="animation-delay:0.3s"></span>
                      <span class="fr-dot r" style="animation-delay:0.8s"></span>
                    </div>
                    <span class="flow-label">检索策略 ↓ · 候选集 ↑</span>
                  </div>
        
                  <!-- ━━ Layer 5: 多路检索 (dim) ━━ -->
                  <div class="arch-row t-dgreen is-dim" data-layer="5" data-layer-name="多路检索">
                    <div class="arch-side"><i class="ri-route-line side-icon"></i>多路检索</div>
                    <div class="arch-body">
                      <div class="arch-chip c-dgreen" data-focus="dense">稠密向量<span class="chip-sub">Dense</span></div>
                      <div class="arch-chip c-dgreen" data-focus="sparse">稀疏向量<span class="chip-sub">Sparse</span></div>
                      <div class="arch-chip c-dgreen" data-focus="fulltext">全文检索<span class="chip-sub">BM25</span></div>
                    </div>
                  </div>
        
                  <!-- Flow L5 → L6 -->
                  <div class="flow-conn">
                    <div class="flow-rail">
                      <div class="fr-line"></div><div class="fr-line2"></div>
                      <span class="fr-dot q" style="animation-delay:0.4s"></span>
                      <span class="fr-dot r" style="animation-delay:0.9s"></span>
                    </div>
                    <span class="flow-label">索引查询 ↓ · Top-K ↑</span>
                  </div>
        
                  <!-- ━━ Layer 6: 算法 (simplified + dim) ━━ -->
                  <div class="arch-row t-lblue is-dim" data-layer="6" data-layer-name="算法">
                    <div class="arch-side"><i class="ri-cpu-line side-icon"></i>算法</div>
                    <div class="arch-body">
                      <div class="arch-chip c-lblue" style="flex:1;" data-focus="hnsw">HNSW 内存索引<span class="chip-sub">FLAT · SQ8 · BQ</span></div>
                      <div class="arch-chip c-lblue" style="flex:1;" data-focus="ivf">IVF 磁盘索引<span class="chip-sub">FLAT · PQ</span></div>
                    </div>
                  </div>
        
                  <!-- Flow L6 → L7 -->
                  <div class="flow-conn">
                    <div class="flow-rail">
                      <div class="fr-line"></div><div class="fr-line2"></div>
                      <span class="fr-dot q" style="animation-delay:0.5s"></span>
                      <span class="fr-dot r" style="animation-delay:1.0s"></span>
                    </div>
                    <span class="flow-label">距离计算 ↓ · 得分 ↑</span>
                  </div>
        
                  <!-- ━━ Layer 7: 算力 (simplified + dim) ━━ -->
                  <div class="arch-row t-compute is-dim" data-layer="7" data-layer-name="算力">
                    <div class="arch-side"><i class="ri-server-line side-icon"></i>算力</div>
                    <div class="arch-body">
                      <div class="arch-chip c-dgray" style="flex:1;" data-focus="compute">跨平台算力<span class="chip-sub">GPU · X86 · ARM</span></div>
                    </div>
                  </div>
                </div><!-- /arch-stack -->
        
                <!-- Focus detail panel -->
                <div class="focus-panel" id="focusPanel">
                  <div id="focusContent">
                    <span class="focus-placeholder"><i class="ri-cursor-line"></i> 点击 Landscape 节点查看详情</span>
                  </div>
                </div>
              </div><!-- /land-left -->
        
              <!-- ═══ RIGHT 30%: OB AI Ecosystem Nav ═══ -->
              <div class="land-right">
                <div class="eco-panel">
                  <div class="eco-panel-head">
                    <div class="eco-panel-icon"><i class="ri-rocket-2-line"></i></div>
                    <div class="eco-panel-title">OB AI 生态</div>
                  </div>
                  <div class="eco-panel-sub">OceanBase AI Ecosystem</div>
        
                  <div class="eco-section-label">集成框架 Integration</div>
                  <a class="eco-item" href="ob-langchain/index.html" data-eco="langchain">
                    <div class="eco-dot blue"></div>
                    <div class="eco-info">
                      <div class="eco-name">OB x LangChain</div>
                      <div class="eco-desc">RAG · Agent · VectorStore</div>
                    </div>
                    <i class="ri-arrow-right-s-line eco-arrow"></i>
                  </a>
                  <a class="eco-item" href="ob-dify/index.html" data-eco="dify">
                    <div class="eco-dot teal"></div>
                    <div class="eco-info">
                      <div class="eco-name">OB x Dify</div>
                      <div class="eco-desc">Workflow · 知识库 · 插件</div>
                    </div>
                    <i class="ri-arrow-right-s-line eco-arrow"></i>
                  </a>
                  <a class="eco-item" href="ob-ragflow/index.html" data-eco="ragflow">
                    <div class="eco-dot blue"></div>
                    <div class="eco-info">
                      <div class="eco-name">OB x RAGFlow</div>
                      <div class="eco-desc">PowerRAG · 多模态 · Memory</div>
                    </div>
                    <i class="ri-arrow-right-s-line eco-arrow"></i>
                  </a>
                  <div class="eco-item" data-eco="llamaindex">
                    <div class="eco-dot green"></div>
                    <div class="eco-info">
                      <div class="eco-name">OB x LlamaIndex</div>
                      <div class="eco-desc">Data Framework · Index · Query</div>
                    </div>
                    <i class="ri-arrow-right-s-line eco-arrow"></i>
                  </div>
                  <div class="eco-item" data-eco="springai">
                    <div class="eco-dot gray"></div>
                    <div class="eco-info">
                      <div class="eco-name">OB x Spring AI</div>
                      <div class="eco-desc">Java · VectorStore · Embedding</div>
                    </div>
                    <i class="ri-arrow-right-s-line eco-arrow"></i>
                  </div>
                  <div class="eco-item" data-eco="dbgpt">
                    <div class="eco-dot teal"></div>
                    <div class="eco-info">
                      <div class="eco-name">OB x DB-GPT</div>
                      <div class="eco-desc">Text2SQL · KBQA · Agent</div>
