          <script>
          (function() {
            var focusData = {
              rag:        { title: 'RAG (Retrieval-Augmented Generation)', layer: 'L1 Applications', color: '#2aa84a', desc: 'RAG combines LLMs with external knowledge bases, using vector retrieval to recall relevant document chunks and inject them into the prompt for more accurate, grounded responses. OceanBase provides high-performance vector indexes and hybrid scalar-vector search, making it an ideal storage backend for RAG.', tags: ['VectorStore', 'Embedding', 'Rerank', 'Chunk', 'Context Window'] },
              semantic:   { title: 'Semantic Search', layer: 'L1 Applications', color: '#2aa84a', desc: 'Vector similarity-based semantic search understands query intent beyond keyword matching. OceanBase HNSW/IVF indexes support millisecond-level ANN retrieval, combined with scalar filtering for precise semantic + structured hybrid queries.', tags: ['ANN', 'Cosine Similarity', 'L2', 'Inner Product'] },
              multimodal: { title: 'Multi-Modal Search', layer: 'L1 Applications', color: '#2aa84a', desc: 'Unified vector encoding and cross-modal retrieval for text, images, audio and more. Generate multi-modal embeddings via CLIP, ImageBind, etc., store in OceanBase vector columns for efficient retrieval.', tags: ['CLIP', 'ImageBind', 'Cross-Modal', 'Multi-Vector'] },
              agent:      { title: 'AI Agents', layer: 'L1 Applications', color: '#2aa84a', desc: 'AI Agents use tool calls, memory management, and planning/reasoning to complete complex tasks. OceanBase serves as a long-term memory and knowledge retrieval backend, providing persistent vector storage with transaction guarantees.', tags: ['Tool Use', 'Memory', 'Planning', 'ReAct'] },
              langchain:  { title: 'LangChain', layer: 'L2 AI Ecosystem', color: '#2f7dd1', desc: 'LangChain is the most popular LLM application framework. OceanBase provides an official langchain-oceanbase integration (github.com/oceanbase/langchain-oceanbase), offering VectorStore implementation with HNSW/IVF indexes, metadata filtering, and full-text search support.', tags: ['VectorStore', 'Retriever', 'Agent', 'Chain'] },
              llamaindex: { title: 'LlamaIndex', layer: 'L2 AI Ecosystem', color: '#2f7dd1', desc: 'LlamaIndex is a data indexing framework connecting private data to LLMs. OceanBase integrates via llama-index-vector-stores-oceanbase (part of LlamaHub), using pyobvector for high-performance vector storage with metadata filtering and hybrid search.', tags: ['Index', 'Query Engine', 'Router', 'Sub-Question'] },
              fastgpt:    { title: 'FastGPT', layer: 'L2 AI Ecosystem', color: '#2f7dd1', desc: 'FastGPT is an LLM-powered knowledge QA platform with visual workflow orchestration. OceanBase can serve as its database backend, providing vector storage and retrieval capabilities for large-scale knowledge base operations.', tags: ['Knowledge QA', 'Workflow', 'API'] },
              dify:       { title: 'Dify', layer: 'L2 AI Ecosystem', color: '#2f7dd1', desc: 'Dify is an open-source LLM app platform with visual workflows. Dify officially supports OceanBase as vector store backend (github.com/langgenius/dify/issues/9982).', tags: ['Workflow', 'Knowledge Base', 'Plugin', 'RAG'] },
              dbgpt:      { title: 'DB-GPT', layer: 'L2 AI Ecosystem', color: '#2f7dd1', desc: 'DB-GPT is a database-centric AI Agent framework supporting Text2SQL, KBQA, and Data Agent. OceanBase is officially supported as both datasource provider and RAG storage (via storage_obvector), enabling unified business database and vector storage.', tags: ['Text2SQL', 'KBQA', 'Data Agent', 'AWEL'] },
              springai:   { title: 'Alibaba Spring AI', layer: 'L2 AI Ecosystem', color: '#2f7dd1', desc: 'Spring AI is a Java AI abstraction framework. The spring-ai-alibaba project (community/vector-stores/spring-ai-alibaba-starter-oceanbase-store) provides OceanBase VectorStore support, enabling Java developers to use vector search via Spring Data patterns.', tags: ['Java', 'VectorStore', 'Embedding', 'Chat Client'] },
              ragflow:    { title: 'RAGFlow', layer: 'L2 AI Ecosystem', color: '#2f7dd1', desc: 'RAGFlow is an open-source RAG engine focused on deep document understanding. OceanBase powers the PowerRAG platform (github.com/oceanbase/powerrag), a production-grade RAG application built on OceanBase\'s multi-modal database architecture (SQL + NoSQL).', tags: ['DeepDoc', 'PowerRAG', 'Multi-Modal', 'Chunk'] },
              autogen:    { title: 'AutoGen', layer: 'L2 AI Ecosystem', color: '#2f7dd1', desc: 'AutoGen is Microsoft\'s open-source multi-agent conversation framework. OceanBase can serve as its knowledge base backend, providing persistent vector storage for agent memory, conversation history, and retrieval-augmented generation.', tags: ['Multi-Agent', 'Conversation', 'Code Execution'] },
              crewai:     { title: 'CrewAI', layer: 'L2 AI Ecosystem', color: '#2f7dd1', desc: 'CrewAI is a role-driven multi-agent orchestration framework. OceanBase can serve as its long-term memory and knowledge retrieval backend, providing distributed vector storage for agent collaboration and task context persistence.', tags: ['Agent Orchestration', 'Role-Based', 'Tool Use'] },
              pysdk:      { title: 'Python SDK', layer: 'L3 SDK', color: '#7a7d82', desc: 'pyobvector provides a Milvus-compatible Python interface with SQLAlchemy ORM support; pyseekdb offers lightweight schemaless access. Together they cover rapid prototyping to production deployment.', tags: ['pyobvector', 'pyseekdb', 'SQLAlchemy', 'pip install'] },
              javasdk:    { title: 'Java SDK', layer: 'L3 SDK', color: '#7a7d82', desc: 'Through MySQL-compatible JDBC Connector/J and Spring Data integration, Java applications can directly use SQL to access vector search capabilities without additional drivers.', tags: ['Connector/J', 'Spring Data', 'JDBC', 'MySQL Protocol'] },
              mysqlclient:{ title: 'MySQL Multi-Language Clients', layer: 'L3 SDK', color: '#7a7d82', desc: 'OceanBase is MySQL-protocol compatible. MySQL drivers for Go, Rust, Node.js, PHP and more can connect directly, executing vector search and full-text queries via SQL.', tags: ['Go', 'Rust', 'Node.js', 'PHP', 'MySQL Compatible'] },
              scalarvec:  { title: 'Scalar+Vector Filter', layer: 'L4 Hybrid Search', color: '#2f7dd1', desc: 'Apply scalar conditions alongside vector search. Supports Pre-filter (filter then search), In-filter (filter during search), and Post-filter (search then filter) strategies — the engine auto-selects the optimal path. Developers just write SQL WHERE clauses.', tags: ['Pre-filter', 'In-filter', 'Post-filter', 'Brute-force'] },
              multivec:   { title: 'Multi-Vector', layer: 'L4 Hybrid Search', color: '#2f7dd1', desc: 'Store multiple vectors per record (e.g., multiple chunk embeddings per document). Search returns the parent record by the most similar vector. Ideal for long-document chunked retrieval.', tags: ['Multi-Embedding', 'Parent-Child', 'Chunk Retrieval'] },
              ftvec:      { title: 'Full-Text+Vector', layer: 'L4 Hybrid Search', color: '#2f7dd1', desc: 'Combine full-text index (BM25) and vector index (ANN) for hybrid search, merging results via RRF or weighted fusion. Balances keyword precision with semantic understanding.', tags: ['BM25 + ANN', 'RRF Fusion', 'Hybrid Score'] },
              dense:      { title: 'Dense Vector', layer: 'L5 Retrieval', color: '#1e8e3e', desc: 'Encode text into high-dimensional dense vectors via Dense Embedding, then perform approximate nearest neighbor search via HNSW/IVF indexes. Strong semantic understanding.', tags: ['Dense Embedding', 'HNSW', 'IVF'] },
              sparse:     { title: 'Sparse Vector', layer: 'L5 Retrieval', color: '#1e8e3e', desc: 'Generate sparse vectors via SPLADE, BGE-M3, etc. Balances lexical matching with semantic expansion.', tags: ['SPLADE', 'BGE-M3', 'Learned Sparse'] },
              fulltext:   { title: 'Full-Text', layer: 'L5 Retrieval', color: '#1e8e3e', desc: 'Inverted index-based full-text search (BM25) with tokenization and phrase queries, complementing vector retrieval.', tags: ['BM25', 'Full-Text', 'Tokenizer'] },
              hnsw:       { title: 'HNSW In-Memory Index', layer: 'L6 Algorithms', color: '#4aa3df', desc: 'HNSW-based in-memory vector index supporting FLAT (full precision), SQ8 (scalar quantization, 75% memory reduction), and BQ (binary quantization, 97% memory reduction). Choose based on data scale and recall requirements.', tags: ['HNSW_FLAT', 'HNSW_SQ8', 'HNSW_BQ', 'Memory-Based'] },
              ivf:        { title: 'IVF On-Disk Index', layer: 'L6 Algorithms', color: '#4aa3df', desc: 'IVF-based on-disk vector index supporting FLAT (full precision) and PQ (product quantization) modes. Ideal for large-scale datasets that cannot fit entirely in memory.', tags: ['IVF_FLAT', 'IVF_PQ', 'Disk-Based', 'Billion-Scale'] },
              compute:    { title: 'Cross-Platform Compute', layer: 'L7 Compute', color: '#6b6f74', desc: 'OceanBase vector engine supports GPU (CUDA/ROCm), X86 (AVX-512/SSE), and ARM (NEON/SVE) acceleration, automatically selecting the optimal SIMD instruction path for the current platform.', tags: ['GPU', 'X86', 'ARM', 'SIMD'] },
            };
        
            var stack = document.getElementById('archStack');
            var panel = document.getElementById('focusPanel');
            var content = document.getElementById('focusContent');
            var allRows = stack.querySelectorAll('.arch-row');
            var allChips = stack.querySelectorAll('.arch-chip:not(.c-dots)');
        
            var currentFocus = null;
        
            function clearFocus() {
              allRows.forEach(function(r) { r.classList.remove('is-active'); });
              allChips.forEach(function(c) { c.classList.remove('is-focused'); });
              document.querySelectorAll('.eco-item.is-active').forEach(function(e) { e.classList.remove('is-active'); });
            }
        
            function setFocus(key) {
              var data = focusData[key];
              if (!data) return;
              clearFocus();
              currentFocus = key;
        
              var chip = stack.querySelector('[data-focus="' + key + '"]');
              if (chip) {
                chip.classList.add('is-focused');
                var row = chip.closest('.arch-row');
                if (row) row.classList.add('is-active');
              }
        
              panel.classList.add('has-focus');
              var tagsHtml = data.tags.map(function(t) { return '<span class="focus-tag">' + t + '</span>'; }).join('');
              content.innerHTML =
                '<div class="focus-panel-header">' +
                  '<div class="focus-panel-dot" style="background:' + data.color + ';"></div>' +
                  '<div class="focus-panel-title">' + data.title + '</div>' +
                  '<div class="focus-panel-layer">' + data.layer + '</div>' +
                '</div>' +
                '<div class="focus-panel-desc">' + data.desc + '</div>' +
                '<div class="focus-panel-tags">' + tagsHtml + '</div>';
        
              var ecoItem = document.querySelector('.eco-item[data-eco="' + key + '"]');
              if (ecoItem) ecoItem.classList.add('is-active');
            }
        
            allChips.forEach(function(el) {
              el.addEventListener('click', function(e) {
                var key = el.getAttribute('data-focus');
                if (!key) return;
                if (el.tagName === 'A') {
                  if (currentFocus === key) return;
                  e.preventDefault();
                }
                setFocus(key);
              });
            });
        
            document.querySelectorAll('.eco-item[data-eco]').forEach(function(item) {
              item.addEventListener('click', function(e) {
                var key = item.getAttribute('data-eco');
                if (key && focusData[key]) {
                  // For <a> items with href, first click = focus, second click = navigate
                  if (item.tagName === 'A' && item.getAttribute('href')) {
                    if (currentFocus !== key) e.preventDefault();
                  }
                  setFocus(key);
                  var chip = stack.querySelector('[data-focus="' + key + '"]');
                  if (chip) chip.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
              });
            });
        
            allRows.forEach(function(row) {
              var side = row.querySelector('.arch-side');
              if (side) {
                side.addEventListener('click', function() {
                  var firstChip = row.querySelector('[data-focus]');
                  if (firstChip) setFocus(firstChip.getAttribute('data-focus'));
                });
              }
            });
        
            setFocus('rag');
          })();
          </script>
        </body>
        </html>
        
