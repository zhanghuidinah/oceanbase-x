                    <!-- ══ Slide 2 · RAGFlow Overview ══ -->
                    <section data-background-color="#fafafa">
                        <div class="slide-label"><span class="pill">RAGFlow 简介</span></div>
                        <h2 class="slide-title">RAGFlow — 深度文档理解 RAG 引擎</h2>
                        <div class="feature-grid" style="margin-top:1.2rem;">
                            <div class="feature-card">
                                <div class="feature-icon"><i class="ri-file-search-line" style="color:var(--ob-blue);"></i></div>
                                <h4>深度文档解析</h4>
                                <p>PDF / Excel / 图片 / PPT 多格式解析，保留结构化信息</p>
                            </div>
                            <div class="feature-card">
                                <div class="feature-icon"><i class="ri-puzzle-line" style="color:var(--ob-teal);"></i></div>
                                <h4>可组分块</h4>
                                <p>手动 / 自动 / Q&A / Table / Paper 多种分块策略</p>
                            </div>
                            <div class="feature-card">
                                <div class="feature-icon"><i class="ri-robot-2-line" style="color:var(--ob-blue);"></i></div>
                                <h4>Agent 编排</h4>
                                <p>可视化 Agent Flow，支持工具调用、条件分支、循环</p>
                            </div>
                            <div class="feature-card">
                                <div class="feature-icon"><i class="ri-brain-line" style="color:var(--ob-teal);"></i></div>
