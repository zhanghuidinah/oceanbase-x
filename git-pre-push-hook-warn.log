                    <!-- ══ Slide 2 · Why OceanBase for AI ══ -->
                    <section data-background-color="#fafafa">
                        <div class="slide-label"><span class="pill">Context</span></div>
                        <h2 class="slide-title">Why AI Apps Need OceanBase</h2>
                        <div class="grid-2" style="margin-top:1.5rem;">
                            <div class="callout">
                                <strong><i class="ri-database-2-line" style="color:var(--ob-blue);margin-right:4px;"></i> Data Silo Explosion</strong>
                                <p>Vectors, JSON, full-text, GIS scattered across engines. Developers forced to stitch MySQL + ES + Pinecone into a Frankenstein architecture.</p>
                            </div>
