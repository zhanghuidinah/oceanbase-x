                                <div style="color:#fff;font-size:0.9rem;font-weight:600;">多语言分词</div>
                            </div>
                            <div style="background:rgba(255,255,255,0.15);border-radius:var(--radius);padding:0.8rem 1.2rem;">
                                <div style="color:rgba(255,255,255,0.6);font-size:0.7rem;">最低配置</div>
                                <div style="color:#fff;font-size:0.9rem;font-weight:600;">1C2G</div>
