          </main>
        
          <script>
            // Stagger flow particle delays for visual richness
            document.querySelectorAll('.flow-line').forEach((el, i) => {
              if (!el.style.animationDelay) {
                el.style.animationDelay = (i * 0.3) + 's';
              }
            });
            document.querySelectorAll('.h-flow-line').forEach((el, i) => {
              if (!el.style.animationDelay) {
                el.style.animationDelay = (i * 0.4) + 's';
              }
            });
          </script>
        
        </body>
