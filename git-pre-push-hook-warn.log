          <script>
          (function() {
            var focusData = {
              // ── L1 应用场景 ──
              rag:        { title: '检索增强生成 (RAG)', layer: 'L1 应用场景', color: '#2aa84a', desc: 'RAG 将大语言模型与外部知识库结合，通过向量检索召回相关文档片段，注入 Prompt 以生成更准确、更有依据的回答。OceanBase 提供高性能向量索引与标量过滤的混合检索能力，是 RAG 场景的理想存储后端。', tags: ['VectorStore', 'Embedding', 'Rerank', 'Chunk', 'Context Window'] },
              semantic:   { title: '语义搜索', layer: 'L1 应用场景', color: '#2aa84a', desc: '基于向量相似度的语义搜索，能够理解查询意图而非仅匹配关键词。OceanBase 的 HNSW/IVF 索引支持毫秒级 ANN 检索，结合标量过滤实现精准的语义+结构化混合查询。', tags: ['ANN', 'Cosine Similarity', 'L2', 'Inner Product'] },
              multimodal: { title: '多模态搜索', layer: 'L1 应用场景', color: '#2aa84a', desc: '支持文本、图像、音频等多种模态的统一向量编码与跨模态检索。通过 CLIP、ImageBind 等模型生成多模态 Embedding，存入 OceanBase 向量列进行高效检索。', tags: ['CLIP', 'ImageBind', 'Cross-Modal', 'Multi-Vector'] },
              agent:      { title: '智能体应用', layer: 'L1 应用场景', color: '#2aa84a', desc: 'AI Agent 利用工具调用、记忆管理和规划推理完成复杂任务。OceanBase 作为长期记忆和知识检索后端，为 Agent 提供持久化的向量存储与事务保障。', tags: ['Tool Use', 'Memory', 'Planning', 'ReAct'] },
              // ── L2 生态集成 ──
              langchain:  { title: 'LangChain', layer: 'L2 AI 生态', color: '#2f7dd1', desc: 'LangChain 是最流行的 LLM 应用开发框架。OceanBase 提供官方 langchain-oceanbase 集成（github.com/oceanbase/langchain-oceanbase），提供 VectorStore 实现，支持 HNSW/IVF 索引、元数据过滤和全文搜索。', tags: ['VectorStore', 'Retriever', 'Agent', 'Chain'] },
              llamaindex: { title: 'LlamaIndex', layer: 'L2 AI 生态', color: '#2f7dd1', desc: 'LlamaIndex 是数据索引与检索框架，专注于将私有数据接入 LLM。OceanBase 通过 llama-index-vector-stores-oceanbase（LlamaHub 的一部分）集成，使用 pyobvector 实现高性能向量存储，支持元数据过滤和混合检索。', tags: ['Index', 'Query Engine', 'Router', 'Sub-Question'] },
              fastgpt:    { title: 'FastGPT', layer: 'L2 AI 生态', color: '#2f7dd1', desc: 'FastGPT 是基于 LLM 的知识库问答平台，支持可视化 Workflow 编排。OceanBase 可作为其数据库后端，提供向量存储和检索能力，支持大规模知识库操作。', tags: ['Knowledge QA', 'Workflow', 'API'] },
              dify:       { title: 'Dify', layer: 'L2 AI 生态', color: '#2f7dd1', desc: 'Dify 是开源 LLM 应用开发平台，提供可视化 Workflow、知识库管理和插件生态。Dify 官方支持 OceanBase 作为向量存储后端（github.com/langgenius/dify/issues/9982）。', tags: ['Workflow', 'Knowledge Base', 'Plugin', 'RAG'] },
              dbgpt:      { title: 'DB-GPT', layer: 'L2 AI 生态', color: '#2f7dd1', desc: 'DB-GPT 是数据库领域的 AI Agent 框架，支持 Text2SQL、KBQA、Data Agent 等场景。OceanBase 官方支持作为数据源提供商和 RAG 存储（通过 storage_obvector），实现业务数据库与向量存储的统一。', tags: ['Text2SQL', 'KBQA', 'Data Agent', 'AWEL'] },
              springai:   { title: 'Alibaba Spring AI', layer: 'L2 AI 生态', color: '#2f7dd1', desc: 'Spring AI 是 Java 生态的 AI 抽象框架。spring-ai-alibaba 项目（community/vector-stores/spring-ai-alibaba-starter-oceanbase-store）提供 OceanBase VectorStore 支持，使 Java 开发者可通过 Spring Data 模式使用向量搜索。', tags: ['Java', 'VectorStore', 'Embedding', 'Chat Client'] },
              ragflow:    { title: 'RAGFlow', layer: 'L2 AI 生态', color: '#2f7dd1', desc: 'RAGFlow 是专注于深度文档理解和 RAG 的开源引擎。OceanBase 支撑了 PowerRAG 平台（github.com/oceanbase/powerrag），这是一个基于 OceanBase 多模态数据库架构（SQL + NoSQL）的生产级 RAG 应用平台。', tags: ['DeepDoc', 'PowerRAG', 'Multi-Modal', 'Chunk'] },
              autogen:    { title: 'AutoGen', layer: 'L2 AI 生态', color: '#2f7dd1', desc: 'AutoGen 是微软开源的多智能体对话框架。OceanBase 可作为其知识库后端，提供持久的向量存储，用于 Agent 记忆、对话历史和检索增强生成。', tags: ['Multi-Agent', 'Conversation', 'Code Execution'] },
              crewai:     { title: 'CrewAI', layer: 'L2 AI 生态', color: '#2f7dd1', desc: 'CrewAI 是角色驱动的多智能体编排框架。OceanBase 可作为其长期记忆和知识检索后端，提供分布式向量存储，用于 Agent 协作和任务上下文持久化。', tags: ['Agent Orchestration', 'Role-Based', 'Tool Use'] },
              // ── L3 用户接口 ──
              pysdk:      { title: 'Python SDK', layer: 'L3 用户接口', color: '#7a7d82', desc: 'pyobvector 提供 Milvus 兼容的 Python 接口，支持 SQLAlchemy ORM；pyseekdb 提供轻量级 Schemaless 访问。两个 SDK 覆盖从快速原型到生产部署的全场景。', tags: ['pyobvector', 'pyseekdb', 'SQLAlchemy', 'pip install'] },
              javasdk:    { title: 'Java SDK', layer: 'L3 用户接口', color: '#7a7d82', desc: '通过 MySQL 兼容的 JDBC Connector/J 和 Spring Data 集成，Java 应用可直接使用 SQL 访问向量检索能力，无需额外驱动。', tags: ['Connector/J', 'Spring Data', 'JDBC', 'MySQL Protocol'] },
              mysqlclient:{ title: 'MySQL 多语言客户端', layer: 'L3 用户接口', color: '#7a7d82', desc: 'OceanBase 兼容 MySQL 协议，Go、Rust、Node.js、PHP 等语言的 MySQL 驱动均可直连，通过 SQL 语句执行向量检索和全文搜索。', tags: ['Go', 'Rust', 'Node.js', 'PHP', 'MySQL Compatible'] },
              // ── L4 混合检索 (simplified) ──
              scalarvec:  { title: '标量+向量过滤', layer: 'L4 混合检索', color: '#2f7dd1', desc: '在向量检索的同时进行标量条件过滤，支持 Pre-filter（先过滤再检索）、In-filter（检索中过滤）、Post-filter（检索后过滤）三种策略，引擎自动选择最优路径。开发者只需写 SQL WHERE 条件即可。', tags: ['Pre-filter', 'In-filter', 'Post-filter', 'Brute-force'] },
              multivec:   { title: '多向量检索', layer: 'L4 混合检索', color: '#2f7dd1', desc: '支持单条记录存储多个向量（如文档的多个 Chunk Embedding），检索时按最相似的向量返回父记录。适用于长文档分块检索场景。', tags: ['Multi-Embedding', 'Parent-Child', 'Chunk Retrieval'] },
              ftvec:      { title: '全文+向量', layer: 'L4 混合检索', color: '#2f7dd1', desc: '同时利用全文索引（BM25）和向量索引（ANN）进行混合检索，通过 RRF 或加权融合合并结果。兼顾关键词精确匹配和语义理解。', tags: ['BM25 + ANN', 'RRF Fusion', 'Hybrid Score'] },
              // ── L5 多路检索 (dim) ──
              dense:      { title: '稠密向量', layer: 'L5 多路检索', color: '#1e8e3e', desc: '使用 Dense Embedding 将文本编码为高维稠密向量，通过 HNSW/IVF 索引进行近似最近邻搜索，语义理解能力强。', tags: ['Dense Embedding', 'HNSW', 'IVF'] },
              sparse:     { title: '稀疏向量', layer: 'L5 多路检索', color: '#1e8e3e', desc: '使用 Sparse Embedding（如 SPLADE、BGE-M3）生成稀疏向量，兼顾词汇匹配与语义扩展。', tags: ['SPLADE', 'BGE-M3', 'Learned Sparse'] },
              fulltext:   { title: '全文检索', layer: 'L5 多路检索', color: '#1e8e3e', desc: '基于倒排索引的全文检索（BM25），支持分词和短语查询，与向量检索互补。', tags: ['BM25', 'Full-Text', 'Tokenizer'] },
              // ── L6 算法 (simplified + dim) ──
              hnsw:       { title: 'HNSW 内存索引', layer: 'L6 算法', color: '#4aa3df', desc: '基于 HNSW 算法的内存向量索引，支持 FLAT（全精度）、SQ8（标量量化，内存减 75%）、BQ（二值量化，内存减 97%）三种精度级别，可根据数据规模和召回要求灵活选择。', tags: ['HNSW_FLAT', 'HNSW_SQ8', 'HNSW_BQ', 'Memory-Based'] },
              ivf:        { title: 'IVF 磁盘索引', layer: 'L6 算法', color: '#4aa3df', desc: '基于 IVF 算法的磁盘向量索引，支持 FLAT（全精度）和 PQ（乘积量化）两种模式，适合无法全部放入内存的大规模数据集。', tags: ['IVF_FLAT', 'IVF_PQ', 'Disk-Based', 'Billion-Scale'] },
              // ── L7 算力 (simplified + dim) ──
              compute:    { title: '跨平台算力', layer: 'L7 算力', color: '#6b6f74', desc: 'OceanBase 向量引擎支持 GPU（CUDA/ROCm）、X86（AVX-512/SSE）和 ARM（NEON/SVE）多平台加速，自动选择当前平台最优的 SIMD 指令路径。', tags: ['GPU', 'X86', 'ARM', 'SIMD'] },
            };
        
            var stack = document.getElementById('archStack');
            var panel = document.getElementById('focusPanel');
            var content = document.getElementById('focusContent');
            var allRows = stack.querySelectorAll('.arch-row');
            var allChips = stack.querySelectorAll('.arch-chip:not(.c-dots)');
        
            var currentFocus = null;
        
            function clearFocus() {
              allRows.forEach(function(r) { r.classList.remove('is-active'); });
              allChips.forEach(function(c) { c.classList.remove('is-focused'); });
              document.querySelectorAll('.eco-item.is-active').forEach(function(e) { e.classList.remove('is-active'); });
            }
        
            function setFocus(key) {
              var data = focusData[key];
              if (!data) return;
              clearFocus();
              currentFocus = key;
        
              var chip = stack.querySelector('[data-focus="' + key + '"]');
              if (chip) {
                chip.classList.add('is-focused');
                var row = chip.closest('.arch-row');
                if (row) row.classList.add('is-active');
              }
        
              panel.classList.add('has-focus');
              var tagsHtml = data.tags.map(function(t) { return '<span class="focus-tag">' + t + '</span>'; }).join('');
              content.innerHTML =
                '<div class="focus-panel-header">' +
                  '<div class="focus-panel-dot" style="background:' + data.color + ';"></div>' +
                  '<div class="focus-panel-title">' + data.title + '</div>' +
                  '<div class="focus-panel-layer">' + data.layer + '</div>' +
                '</div>' +
                '<div class="focus-panel-desc">' + data.desc + '</div>' +
                '<div class="focus-panel-tags">' + tagsHtml + '</div>';
        
              var ecoItem = document.querySelector('.eco-item[data-eco="' + key + '"]');
              if (ecoItem) ecoItem.classList.add('is-active');
            }
        
            allChips.forEach(function(el) {
              el.addEventListener('click', function(e) {
                var key = el.getAttribute('data-focus');
                if (!key) return;
                if (el.tagName === 'A') {
                  if (currentFocus === key) return;
                  e.preventDefault();
                }
                setFocus(key);
              });
            });
        
            document.querySelectorAll('.eco-item[data-eco]').forEach(function(item) {
              item.addEventListener('click', function(e) {
                var key = item.getAttribute('data-eco');
                if (key && focusData[key]) {
                  // For <a> items with href, first click = focus, second click = navigate
                  if (item.tagName === 'A' && item.getAttribute('href')) {
                    if (currentFocus !== key) e.preventDefault();
                  }
                  setFocus(key);
                  var chip = stack.querySelector('[data-focus="' + key + '"]');
                  if (chip) chip.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
              });
            });
        
            allRows.forEach(function(row) {
              var side = row.querySelector('.arch-side');
              if (side) {
                side.addEventListener('click', function() {
                  var firstChip = row.querySelector('[data-focus]');
                  if (firstChip) setFocus(firstChip.getAttribute('data-focus'));
                });
              }
            });
        
            setFocus('rag');
          })();
          </script>
        </body>
        </html>
        
