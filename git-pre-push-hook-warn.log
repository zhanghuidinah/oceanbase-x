                                    <div style="color:rgba(255,255,255,0.6);font-size:0.7rem;">Metadata</div>
                                    <div style="color:#fff;font-size:0.9rem;font-weight:600;">MySQL Compatible</div>
                                </div>
                                <div style="background:rgba(255,255,255,0.15);border-radius:var(--radius);padding:0.8rem 1.2rem;">
